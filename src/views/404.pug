extends layouts/main-layout

block content
  .error-container(style="text-align: center; margin-top: 50px;")
    h1 404 - Page Not Found
    p.error-text
      | Sorry, the page 
      strong #{path} 
      | does not exist on this server.
    
    div(style="margin-top: 20px;")
      a.btn(href="/dashboard") Return to Dashboard
      span(style="margin: 0 10px;") or
      a(href="/directory") View Directory