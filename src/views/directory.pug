extends layouts/main-layout

block content
  h1 Employee Directory
  p A listing of all current staff and their contact information.
  a.btn(href="/dashboard") ← Back to Admin Dashboard

  if employees.length > 0
    table(style="width:100%; border-collapse: collapse; margin-top: 20px;")
      thead
        tr(style="background-color: #2c3e50; color: white; text-align: left;")
          th(style="padding: 10px;") Name
          th(style="padding: 10px;") Department
          th(style="padding: 10px;") Email
          th(style="padding: 10px;") Contact
          th(style="padding: 10px;") Actions //- New Column Header
      tbody
        each emp in employees
          tr(style="border-bottom: 1px solid #ddd;")
            td(style="padding: 10px;")= emp.name
            td(style="padding: 10px;")= emp.department
            td(style="padding: 10px;")= emp.email
            td(style="padding: 10px;")= emp.phone
            td(style="padding: 10px;")
              //- The form must be inside the td to stay in the row
              form(action=`/employees/delete/${emp.id}`, method="POST" onsubmit="return confirm('Delete this employee?')")
                button(type="submit" class="btn-delete") Delete
  else
    .error-msg No employees found.